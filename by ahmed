-- ==================== دالة جعل أي نافذة قابلة للسحب ====================
local function MakeDraggable(frame, dragBar)
    local dragging = false
    local dragStart, startPos
    
    dragBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    
    dragBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- ==================== تأثيرات ====================
local function CreateBorderGlow(frame, speed)
    local stroke = Instance.new("UIStroke", frame)
    stroke.Thickness = 2
    local hue = 0
    task.spawn(function()
        while frame and frame.Parent do
            hue = (hue + (speed or 0.005)) % 1
            stroke.Color = Color3.fromHSV(hue, 1, 0.9)
            task.wait(0.05)
        end
    end)
    return stroke
end

local function ButtonEffect(btn)
    local origSize = btn.Size
    TweenService:Create(btn, TweenInfo.new(0.05), {Size = UDim2.new(origSize.X.Scale * 0.97, origSize.X.Offset, origSize.Y.Scale * 0.97, origSize.Y.Offset)}):Play()
    task.wait(0.05)
    TweenService:Create(btn, TweenInfo.new(0.05), {Size = origSize}):Play()
end

