    local count = math.clamp(tonumber(LoopCount.Text) or 1, 1, 100000)
    if CommandInput.Text ~= "" then
        for i = 1, count do
            task.spawn(function() remote:InvokeServer(CommandInput.Text) end)
        end
    end
end)

AttackBtn.MouseButton1Click:Connect(function()
    ButtonEffect(AttackBtn)
    attackLoop = not attackLoop
    AttackBtn.Text = attackLoop and "⏹️ إيقاف الهجوم" or "🚀 بدء الهجوم"
    AttackBtn.BackgroundColor3 = attackLoop and Colors.Warning or Colors.Danger
    if attackLoop then
        task.spawn(function()
            while attackLoop do
                local target = TargetInput.Text
                if target ~= "" then
                    for _, cmd in ipairs(attackCommands) do
                        task.spawn(function() remote:InvokeServer(currentPrefix .. cmd:gsub("%[target%]", target)) end)
                    end
                end
                task.wait(0.2)
            end
        end)
    end
end)

HeadlessBtn.MouseButton1Click:Connect(function()
